      "scope": ["comment", "punctuation.definition.comment", "string.comment"],
      "settings": { "foreground": "#3f3f46", "fontStyle": "italic" }
    },
    {
      "name": "Keywords and storage",
      "scope": [
        "keyword", "keyword.control", "keyword.control.flow",
        "keyword.operator.new", "keyword.operator.delete",
        "storage.type", "storage.modifier",
        "keyword.other.important"
      ],
      "settings": { "foreground": "#a1a1aa", "fontStyle": "bold" }
    },
    {
      "name": "Keyword operators (return, typeof, instanceof)",
      "scope": [
        "keyword.operator.expression",
        "keyword.operator.logical.python",
        "keyword.operator.wordlike"
      ],
      "settings": { "foreground": "#a1a1aa", "fontStyle": "bold" }
    },
    {
      "name": "Operators and punctuation",
      "scope": [
        "keyword.operator",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.accessor",
        "punctuation.definition.parameters",
        "punctuation.section",
        "meta.brace",
        "punctuation.bracket"
      ],
      "settings": { "foreground": "#52525b", "fontStyle": "" }
    },
    {
      "name": "Strings",
      "scope": [
        "string", "string.quoted", "string.template",
        "string.regexp", "string.interpolated"
      ],
      "settings": { "foreground": "#a1a1aa", "fontStyle": "" }
    },
    {
      "name": "String escape sequences",
      "scope": ["constant.character.escape", "string.regexp constant.character"],
      "settings": { "foreground": "#d4d4d8", "fontStyle": "bold" }
    },
    {
      "name": "Numbers and constants",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other"
      ],
      "settings": { "foreground": "#d4d4d8", "fontStyle": "" }
    },
    {
      "name": "Boolean",
      "scope": ["constant.language.boolean"],
      "settings": { "foreground": "#d4d4d8", "fontStyle": "bold" }
    },
    {
      "name": "Null / undefined",
      "scope": ["constant.language.null", "constant.language.undefined"],
      "settings": { "foreground": "#52525b", "fontStyle": "bold" }
    },
    {
      "name": "Function definitions",
      "scope": [
        "entity.name.function",
        "meta.function entity.name.function",
        "support.function"
      ],
      "settings": { "foreground": "#e4e4e7", "fontStyle": "bold" }
    },
    {
      "name": "Function calls",
      "scope": ["meta.function-call entity.name.function", "meta.function-call"],
      "settings": { "foreground": "#e4e4e7", "fontStyle": "bold" }
    },
    {
      "name": "Types, classes, interfaces",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.interface",
        "entity.name.struct",
        "entity.name.enum",
        "support.class",
        "support.type"
      ],
      "settings": { "foreground": "#d4d4d8", "fontStyle": "bold" }
    },
    {
      "name": "Type annotations and generics",
      "scope": [
        "meta.type.annotation",
        "meta.type.parameters",
        "entity.name.type.instance",
        "support.type.primitive"
      ],
      "settings": { "foreground": "#d4d4d8", "fontStyle": "" }
    },
    {
      "name": "Variables and parameters",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "variable.parameter"
      ],
      "settings": { "foreground": "#e4e4e7", "fontStyle": "" }
    },
    {
      "name": "Language variables (this, self, super)",
      "scope": ["variable.language"],
      "settings": { "foreground": "#a1a1aa", "fontStyle": "italic" }
    },
    {
      "name": "Object properties",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "meta.object-literal.key"
      ],
      "settings": { "foreground": "#e4e4e7", "fontStyle": "" }
    },
    {
      "name": "Namespace / module",
      "scope": ["entity.name.namespace", "entity.name.module"],
      "settings": { "foreground": "#a1a1aa", "fontStyle": "" }
    },
    {
      "name": "Imports and exports",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as",
        "meta.import",
        "meta.export"
      ],
      "settings": { "foreground": "#71717a", "fontStyle": "" }
    },
    {
      "name": "Decorators and annotations",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator",
