    {
      "name": "HTML / XML tags",
      "scope": [
        "entity.name.tag",
        "meta.tag",
        "punctuation.definition.tag"
      ],
      "settings": { "foreground": "#a1a1aa", "fontStyle": "bold" }
    },
    {
      "name": "HTML / XML attributes",
      "scope": [
        "entity.other.attribute-name",
        "meta.attribute"
      ],
      "settings": { "foreground": "#71717a", "fontStyle": "" }
    },
    {
      "name": "CSS selectors",
      "scope": [
        "entity.name.tag.css",
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css",
        "entity.other.attribute-name.pseudo-class.css",
        "entity.other.attribute-name.pseudo-element.css"
      ],
      "settings": { "foreground": "#a1a1aa", "fontStyle": "bold" }
    },
    {
      "name": "CSS properties",
      "scope": ["support.type.property-name.css", "meta.property-name.css"],
      "settings": { "foreground": "#e4e4e7", "fontStyle": "" }
    },
    {
      "name": "CSS values",
      "scope": [
        "support.constant.property-value.css",
        "meta.property-value.css",
        "constant.other.color.rgb-value.css"
      ],
      "settings": { "foreground": "#a1a1aa", "fontStyle": "" }
    },
    {
      "name": "CSS units and at-rules",
      "scope": [
        "keyword.other.unit.css",
        "keyword.control.at-rule.css",
        "punctuation.definition.keyword.css"
      ],
      "settings": { "foreground": "#71717a", "fontStyle": "" }
    },
    {
      "name": "Markdown headings",
      "scope": ["markup.heading", "entity.name.section.markdown"],
      "settings": { "foreground": "#e4e4e7", "fontStyle": "bold" }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#d4d4d8", "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#a1a1aa", "fontStyle": "italic" }
    },
    {
      "name": "Markdown code",
      "scope": ["markup.inline.raw", "markup.fenced_code.block"],
      "settings": { "foreground": "#a1a1aa", "fontStyle": "" }
    },
    {
      "name": "Markdown links",
      "scope": ["markup.underline.link", "string.other.link"],
      "settings": { "foreground": "#71717a", "fontStyle": "" }
    },
    {
      "name": "Markdown list bullets",
      "scope": ["punctuation.definition.list.begin.markdown"],
      "settings": { "foreground": "#52525b", "fontStyle": "" }
    },
    {
      "name": "Markdown blockquote",
      "scope": ["markup.quote"],
      "settings": { "foreground": "#52525b", "fontStyle": "italic" }
    },
    {
      "name": "JSON keys",
      "scope": ["support.type.property-name.json"],
      "settings": { "foreground": "#a1a1aa", "fontStyle": "" }
    },
    {
      "name": "YAML keys",
      "scope": ["entity.name.tag.yaml"],
      "settings": { "foreground": "#a1a1aa", "fontStyle": "" }
    },
    {
      "name": "TOML keys",
      "scope": ["support.type.property-name.toml", "entity.name.tag.toml"],
      "settings": { "foreground": "#a1a1aa", "fontStyle": "" }
    },
    {
      "name": "Shell commands",
      "scope": ["support.function.builtin.shell", "entity.name.command.shell"],
      "settings": { "foreground": "#e4e4e7", "fontStyle": "bold" }
    },
    {
      "name": "Shell variables",
      "scope": [
        "variable.other.normal.shell",
        "punctuation.definition.variable.shell"
      ],
      "settings": { "foreground": "#e4e4e7", "fontStyle": "" }
    },
    {
      "name": "Invalid / deprecated",
      "scope": ["invalid", "invalid.deprecated"],
      "settings": { "foreground": "#71717a", "fontStyle": "strikethrough" }
    },
    {
      "name": "Diff added",
      "scope": ["markup.inserted", "diff.inserted"],
      "settings": { "foreground": "#a1a1aa", "fontStyle": "" }
    },
    {
      "name": "Diff removed",
      "scope": ["markup.deleted", "diff.deleted"],
      "settings": { "foreground": "#52525b", "fontStyle": "" }
    },
    {
      "name": "Diff header",
      "scope": ["meta.diff.header"],
      "settings": { "foreground": "#3f3f46", "fontStyle": "italic" }
    }
  ]
}
